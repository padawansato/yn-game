{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{
          "type": "command",
          "command": "sh -c 'echo \"$CLAUDE_FILE_PATHS\" | grep -qE \"\\.env(\\..*)?$\" && echo \"BLOCK: .env files should not be edited by Claude. Please edit manually.\" && exit 1 || exit 0'",
          "timeout": 5000
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [{
          "type": "command",
          "command": ".claude/hooks/lint-format.sh",
          "async": true,
          "statusMessage": "Running lint & format..."
        }]
      },
      {
        "matcher": "Write",
        "hooks": [{
          "type": "command",
          "command": ".claude/hooks/lint-format.sh",
          "async": true,
          "statusMessage": "Running lint & format..."
        }]
      }
    ]
  }
}
