{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node"],
    "target": "ES2020",
    "outDir": "./node_modules/.cache/tsc-node"
  },
  "include": ["vite.config.ts", "vitest.config.ts", "src/cli.ts", "src/cli/**/*.ts", "src/debug.ts", "src/core/**/*.ts"]
}
